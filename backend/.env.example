API_NAME=openlibrary
APPCODE=

# LLM adapter 配置
LLM_PROVIDER=dashscope_compatible
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=qwen3.6-plus
LLM_TIMEOUT=120
LLM_CONNECT_TIMEOUT=10
LLM_MAX_RETRIES=2
ANALYSIS_WORKER_CONCURRENCY=1
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3000

# 火山引擎 TOS 对象存储配置
TOS_ACCESS_KEY_ID=your_access_key_id
TOS_SECRET_ACCESS_KEY=your_secret_access_key
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET_NAME=bookcase-img
TOS_REGION=cn-beijing
